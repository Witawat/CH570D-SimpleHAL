{
    // กำหนดให้ .c และ .h ถูกตีความเป็นภาษา C เสมอ
    "files.associations": {
        "*.c": "c",
        "*.h": "c"
    },

    // ปิด format on save (ใช้ clang-format ถ้าต้องการ)
    "editor.formatOnSave": false,
    // ใช้ UTF-8 encoding
    "files.encoding": "utf8",
    // ใช้ CRLF (Windows)
    "files.eol": "\r\n",
    // ใช้ Command Prompt เป็น terminal หลัก
    "terminal.integrated.defaultProfile.windows": "Command Prompt"
}
